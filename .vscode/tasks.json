{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "STM32: Clean + Build + Flash",
      "type": "cmake",
      "command": "cleanRebuild",
      "targets": ["all"],
      "preset": "${command:cmake.activeBuildPresetName}",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "Clean → Build → Flash + Debug (F5)"
    },

    {
      "label": "CMake: Build",
      "type": "cmake",
      "command": "build",
      "targets": ["all"],
      "preset": "${command:cmake.activeBuildPresetName}",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },

    {
      "label": "CMake: Clean",
      "type": "cmake",
      "command": "clean",
      "preset": "${command:cmake.activeBuildPresetName}"
    },

    {
      "label": "STM32: Flash Only (No Build)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "${command:cmake.buildDirectory}", "--target", "flash"],
      "problemMatcher": []
    },

    {
      "label": "Serial Monitor: Open (115200)",
      "type": "shell",
      "command": "${command:serial-monitor.open}",
      "args": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": [],
      "detail": "Opens VS Code Serial Monitor at 115200 baud"
    }
  ]
}
